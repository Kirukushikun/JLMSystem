APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ────────────────────────────────────────────────────────────────────
# Used to send status update emails to requestors (reviewed, approved, rejected, on hold).
# Set MAIL_MAILER=log in local dev to write emails to the log instead of sending them.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.yourprovider.com
MAIL_PORT=587
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=yourpassword
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="JL Monitoring System"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── External Auth API ───────────────────────────────────────────────────────
# Base URL of the organization's authentication server
AUTH_API_BASE_URI=

# Bearer token for the /api/v1/auth/login endpoint
AUTH_API_KEY=

# API key for the /api/v1/users/get-user-id endpoint
AUTH_USER_API_KEY=

# ── User Listing API ────────────────────────────────────────────────────────
# Full endpoint URL for fetching all organization users (used in User Management)
USER_API_ENDPOINT=

# API key for the user listing endpoint
USER_API_KEY=

# ── Cloudflare Turnstile ────────────────────────────────────────────────────
# Bot protection on the public submit form.
# Get keys from: https://dash.cloudflare.com → Turnstile
# Set TURNSTILE_VERIFY=false in local development (Cloudflare blocks localhost)
TURNSTILE_VERIFY=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Laravel Reverb (WebSocket server) ───────────────────────────────────────
# Real-time in-app notification bell. Generate values with: php artisan reverb:install
# In production set REVERB_HOST to your domain and REVERB_SCHEME=https
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ── Firebase Cloud Messaging (FCM) ──────────────────────────────────────────
# OS-level web push notifications (works when browser tab is closed).
# Requires HTTPS in production. Cannot be tested on plain HTTP custom domains.
#
# Backend credentials — from Firebase Console → Project Settings → Service Accounts
# → Generate new private key (download JSON, copy values from it)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=          # Paste the full key including -----BEGIN/END----- with literal \n

# Frontend credentials — from Firebase Console → Project Settings → General
# → Your apps → Web app → SDK setup and configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# VAPID key — from Firebase Console → Project Settings → Cloud Messaging
# → Web Push certificates → Generate key pair
VITE_FIREBASE_VAPID_KEY=
